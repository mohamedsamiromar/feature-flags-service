# Copy this file to .env and fill in real values. Never commit .env to git.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=feature_flags
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Redis
REDIS_URL=redis://redis:6379

# Celery (defaults to REDIS_URL DB 0 if not set)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Cache
FLAG_CACHE_TTL=300

# JWT
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Throttling
THROTTLE_RATE_ANON=60/minute
THROTTLE_RATE_USER=600/minute
THROTTLE_RATE_EVALUATION=1000/minute

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000
